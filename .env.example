# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Database (SQLite default, swap for PostgreSQL in prod)
DATABASE_URL=sqlite:///./gen_agent.db
# DATABASE_URL=postgresql://user:password@localhost:5432/gen_agent

# Simulation defaults
SIM_TICK_INTERVAL_SEC=5
SIM_MAX_AGENTS=20
SIM_INTERACTION_RADIUS=2.0

# Logging
LOG_LEVEL=INFO
