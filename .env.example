# Gen_Agent environment configuration
# Copy to .env and fill in your values

# ------------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------------
LLM_PROVIDER=mock              # ollama | openrouter | council | mock

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=300

# OpenRouter (cloud, free tier available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free
OPENROUTER_TIMEOUT=60

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
DATABASE_URL=sqlite:///./gen_agent.db
# DATABASE_URL=postgresql://user:password@localhost:5432/gen_agent

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
TICK_INTERVAL_SEC=1.0
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Simulation defaults
# ------------------------------------------------------------------
SIM_TICK_INTERVAL_SEC=1.0
SIM_MAX_AGENTS=50
SIM_INTERACTION_RADIUS=2.5

# ------------------------------------------------------------------
# Optional advanced layer flags
# Set any to "true" to activate the corresponding module.
# All default to "false" — core works without them.
# ------------------------------------------------------------------

# Cognitive layer
ENABLE_HRM=false              # Hierarchical Role Management
ENABLE_RLIF=false             # Reinforcement Learning from Interaction Feedback
ENABLE_SEAL=false             # Social Emotional Adaptation Layer
ENABLE_SOCIAL_LEARNING=false  # Evolutionary social imitation + knowledge diffusion

# Social intelligence layer
ENABLE_CONSENSUS=false        # Delphi / Borda / majority consensus
ENABLE_GAME_THEORY=false      # Prisoner's dilemma / Nash equilibrium

# Advanced memory layer
ENABLE_GRAPHRAG=false         # Knowledge graph + graph-expanded retrieval
ENABLE_MARS=false             # Privacy memory access/retention/sharing policies
ENABLE_MEMORY_COMPRESSION=false  # Periodic clustering and compression
ENABLE_VECTOR_MEMORY=false    # FAISS vector store (requires faiss-cpu extra)
ENABLE_LLM_COUNCIL=false      # Multi-provider LLM council (set LLM_PROVIDER=council)

# Dialogue quality (legacy parity — English only)
DIALOGUE_MIN_WORDS=25
DIALOGUE_LANGUAGE=en
ENABLE_LEGACY_DIALOGUE_QUALITY=true
GEN_AGENT_CORE_REGENERATE_THRESHOLD=0.6
GEN_AGENT_SYCOPHANCY_REGENERATE_THRESHOLD=0.35
DIALOGUE_QUALITY_TRACE=output/dialogue_quality.ndjson

# Stanford cognition worker (LLM plans + POI mapping)
ENABLE_STANFORD_WORKER=true

# NEAT evolution
ENABLE_NEAT=false
GEN_AGENT_NEAT_MODE=movement

# Data directory (per-agent memory at data/agents/{id}/memory.db)
GEN_AGENT_DATA_DIR=data
