---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Nuovo Gen_Agent — Multi-Agent Cognitive Simulation">
  <section class="hero">
    <div class="hero-content">
      <h1>Nuovo Gen_Agent</h1>
      <p class="tagline">Modular Multi-Agent Cognitive Simulation</p>
      <p class="description">
        Autonomous AI agents with persistent memory, Big Five personality, local LLM dialogues,
        NEAT evolution, and Stanford-style daily planning — in a tick-based 2D world.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="https://github.com/DavideMeda/Gen_Agent-Multi-agent-cognitive-simulation">View on GitHub</a>
        <a class="btn btn-secondary" href="/architecture">Architecture</a>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/hero-placeholder.svg" alt="Nuovo Gen_Agent simulation" />
    </div>
  </section>

  <section class="features">
    <h2>Features</h2>
    <div class="grid">
      <article><h3>SimEngine</h3><p>Tick loop with POI navigation, emotion contagion, and proximity interactions.</p></article>
      <article><h3>Memory (Dual-mode)</h3><p>Per-agent SQLite locally, PostgreSQL in production. LLM reflections triggered automatically.</p></article>
      <article><h3>LLM Dialogues</h3><p>Ollama with intent packs driven by Big Five traits, emotions, and relationship context.</p></article>
      <article><h3>Stanford GA</h3><p>Plan → reflect → POI override via structured planner and AssociativeMemory bridge.</p></article>
      <article><h3>NEAT</h3><p>Neuroevolution of movement and emotion policies, controllable via REST API.</p></article>
      <article><h3>Enterprise Ready</h3><p>Docker multi-stage build, Alembic migrations, CI/CD with Postgres, pre-commit hooks.</p></article>
    </div>
  </section>
</BaseLayout>
