---
const base = import.meta.env.BASE_URL;
const repo = "https://github.com/DavideMeda/new-gen-agent";
const currentPath = Astro.url.pathname;
---

<header class="wrap">
  <nav class="nav" aria-label="Primary">
    <a class="nav-brand" href={base}>New Gen Agent</a>
    <ul class="nav-links">
      <li><a href={`${base}features`} class={currentPath.includes('features') ? 'active' : ''}>Features</a></li>
      <li><a href={`${base}getting-started`} class={currentPath.includes('getting-started') ? 'active' : ''}>Getting Started</a></li>
      <li><a href={`${base}docs`} class={currentPath.includes('docs') ? 'active' : ''}>Docs</a></li>
      <li><a href={repo} target="_blank" rel="noopener">GitHub</a></li>
    </ul>
  </nav>
</header>
