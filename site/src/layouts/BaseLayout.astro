---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "New Gen Agent — Cognitive Generative Agents",
  description = "Modular generative-agent simulation with memory decay, LLM dialogues, cognitive biases, and a live WebSocket dashboard. Fork of Stanford Generative Agents.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
